# Copy this file to .env on each machine and adjust values locally.
#
# Examples:
#   Pi router connecting to a Mac router:
#     ROS_ZENOH_ROUTER_CONNECT_ENDPOINT=tcp/192.168.50.50:7447
#
#   Mac visualization nodes connecting directly to a Pi router:
#     ROS_ZENOH_SESSION_MODE=client
#     ROS_ZENOH_SESSION_ENDPOINT=tcp/192.168.50.42:7447

RMW_IMPLEMENTATION=rmw_zenoh_cpp

# Applied to ordinary ROS nodes and CLI commands during Pixi activation.
# Leave empty when ROS processes should use the local rmw_zenohd router.
ROS_ZENOH_SESSION_MODE=
ROS_ZENOH_SESSION_ENDPOINT=
ZENOH_SESSION_CONFIG_OVERRIDE=

# Applied only by scripts/run-zenohd.sh.
# Use an explicit IPv4 listen endpoint if IPv6/default listener is problematic.
ROS_ZENOH_ROUTER_LISTEN_ENDPOINT=
ROS_ZENOH_ROUTER_CONNECT_ENDPOINT=
ZENOH_ROUTER_CONFIG_OVERRIDE=
