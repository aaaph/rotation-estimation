# Copy this file to .env on each machine and adjust values locally.
#
# Examples:
#   Pi router connecting to a Mac router:
#     ROS_ZENOH_MODE=router
#     ROS_ZENOH_ENDPOINT=tcp/192.168.50.50:7447
#
#   Mac visualization nodes connecting directly to a Pi router:
#     ROS_ZENOH_MODE=client
#     ROS_ZENOH_ENDPOINT=tcp/192.168.50.42:7447

RMW_IMPLEMENTATION=rmw_zenoh_cpp

# Leave empty when the local Zenoh router should only listen with defaults.
ROS_ZENOH_MODE=
ROS_ZENOH_ENDPOINT=

# Optional escape hatch. If set, this exact value wins over ROS_ZENOH_*.
ZENOH_CONFIG_OVERRIDE=
